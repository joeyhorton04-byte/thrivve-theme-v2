{{ 'thrivve-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .tl-mech__head {
    max-width: 64rem;
    margin-bottom: 5.6rem;
  }

  .tl-mech__steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media screen and (min-width: 750px) {
    .tl-mech__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 4rem;
    }
  }

  .tl-mech__step {
    padding: 3.2rem 0;
    border-top: 1px solid var(--tl-border-dark);
  }

  @media screen and (min-width: 750px) {
    .tl-mech__step {
      padding: 0;
      border-top: none;
    }
  }

  .tl-mech__index {
    font-family: var(--tl-font-display);
    font-weight: 800;
    font-size: 1.3rem;
    color: var(--tl-red);
    letter-spacing: 0.1em;
    margin-bottom: 1.6rem;
    display: block;
  }

  .tl-mech__step h3 {
    font-family: var(--tl-font-display);
    font-weight: 700;
    font-size: 2.1rem;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    margin: 0 0 1.2rem;
    color: var(--tl-black);
  }
</style>

<div class="tl-section tl-section--white">
  <div class="tl-container">
    <div class="tl-mech__head">
      <span class="tl-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="tl-heading tl-heading--lg" style="margin-bottom: 2rem; color: var(--tl-black);">{{ section.settings.heading }}</h2>
      <p class="tl-body">{{ section.settings.description }}</p>
    </div>

    <div class="tl-mech__steps">
      {% for block in section.blocks %}
        <div class="tl-mech__step">
          <span class="tl-mech__index">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p class="tl-body">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
  <div class="tl-wavelength" style="margin-top: 6rem;"></div>
</div>

{% schema %}
{
  "name": "Thrivve Mechanism",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE SCIENCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How red light reaches the follicle"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Red and near-infrared light penetrate the scalp and absorb into cellular mitochondria, increasing ATP production. More cellular energy at the follicle supports the hair growth cycle."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Wavelengths" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "660nm red and 850nm near-infrared LEDs penetrate at different depths to reach the follicle." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Mechanism",
      "blocks": [
        { "type": "step", "settings": { "title": "Wavelengths", "description": "660nm red and 850nm near-infrared LEDs penetrate the scalp at different depths to reach the dermal papilla." } },
        { "type": "step", "settings": { "title": "Absorption", "description": "Light energy is absorbed by mitochondria in scalp cells, increasing ATP (cellular energy) production." } },
        { "type": "step", "settings": { "title": "Stimulation", "description": "Increased cellular energy supports follicles in the anagen (growth) phase and improves local circulation." } }
      ]
    }
  ]
}
{% endschema %}
