{{ 'thrivve-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .tl-results__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3.6rem;
  }

  @media screen and (min-width: 750px) {
    .tl-results__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .tl-results__head {
    max-width: 50rem;
    margin-bottom: 4.8rem;
  }
</style>

<div class="tl-section tl-section--white">
  <div class="tl-container">
    <div class="tl-results__head">
      <span class="tl-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="tl-heading tl-heading--lg" style="color: var(--tl-black);">{{ section.settings.heading }}</h2>
    </div>
    <div class="tl-results__grid">
      {% for block in section.blocks %}
        <div class="tl-stat">
          <span class="tl-stat__number">{{ block.settings.number }}</span>
          <span class="tl-stat__label">{{ block.settings.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Thrivve Results",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "RESULTS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What consistent use looks like" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "94%" },
        { "type": "text", "id": "label", "label": "Label", "default": "Reported visible results" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Results",
      "blocks": [
        { "type": "stat", "settings": { "number": "94%", "label": "Reported visible results" } },
        { "type": "stat", "settings": { "number": "12 WKS", "label": "Avg. time to notice change" } },
        { "type": "stat", "settings": { "number": "10 MIN", "label": "Daily session length" } },
        { "type": "stat", "settings": { "number": "30 DAY", "label": "Money-back guarantee" } }
      ]
    }
  ]
}
{% endschema %}
