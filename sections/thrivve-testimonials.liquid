{{ 'thrivve-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .tl-testi__head {
    max-width: 50rem;
    margin-bottom: 4.8rem;
  }

  .tl-testi__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }

  @media screen and (min-width: 750px) {
    .tl-testi__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tl-testi__card {
    border: 1px solid var(--tl-border);
    border-radius: 6px;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .tl-testi__stars {
    color: var(--tl-red);
    font-size: 1.4rem;
    letter-spacing: 0.2em;
  }

  .tl-testi__quote {
    font-family: var(--tl-font-body);
    font-size: 1.6rem;
    line-height: 1.55;
    color: rgba(250, 250, 250, 0.85);
    margin: 0;
  }

  .tl-testi__author {
    font-family: var(--tl-font-body);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--tl-gray-light);
    text-transform: uppercase;
  }
</style>

<div class="tl-section tl-section--black">
  <div class="tl-container">
    <div class="tl-testi__head">
      <span class="tl-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="tl-heading tl-heading--lg">{{ section.settings.heading }}</h2>
    </div>
    <div class="tl-testi__grid">
      {% for block in section.blocks %}
        <div class="tl-testi__card">
          <span class="tl-testi__stars">★★★★★</span>
          <p class="tl-testi__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          <span class="tl-testi__author">{{ block.settings.author }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Thrivve Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "REAL USERS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Don't take our word for it" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Started noticing less shedding around week 6. Genuinely surprised." },
        { "type": "text", "id": "author", "label": "Author", "default": "Verified buyer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "Started noticing less shedding around week 6. Genuinely surprised.", "author": "Verified buyer" } },
        { "type": "testimonial", "settings": { "quote": "Easy to fit into my morning routine. Doesn't feel like a gimmick.", "author": "Verified buyer" } },
        { "type": "testimonial", "settings": { "quote": "Bought the duo pack so my partner and I could both use it.", "author": "Verified buyer" } }
      ]
    }
  ]
}
{% endschema %}
