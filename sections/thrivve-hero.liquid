{{ 'thrivve-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .tl-hero {
    background: var(--tl-black);
    color: var(--tl-white);
    padding-top: 8rem;
    padding-bottom: 0;
    overflow: hidden;
  }

  .tl-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 5rem;
    padding-bottom: 6rem;
  }

  @media screen and (min-width: 900px) {
    .tl-hero__grid {
      grid-template-columns: 1fr 0.95fr;
      gap: 3rem;
    }
  }

  .tl-hero__copy {
    max-width: 58rem;
  }

  .tl-hero__title {
    margin-bottom: 2.4rem;
  }

  .tl-hero__sub {
    max-width: 46rem;
    margin-bottom: 3.6rem;
  }

  .tl-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    margin-bottom: 4rem;
  }

  .tl-hero__media {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 4px;
    overflow: hidden;
    background: var(--tl-near-black);
  }

  .tl-hero__media img,
  .tl-hero__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tl-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 30%, rgba(232, 40, 28, 0.25), transparent 60%);
    pointer-events: none;
  }

  .tl-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 4.8rem;
    padding-top: 4rem;
    border-top: 1px solid var(--tl-border);
  }

  .tl-hero__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--tl-gray-light);
    font-family: var(--tl-font-body);
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    padding: 2rem;
  }
</style>

<div class="tl-hero">
  <div class="tl-container">
    <div class="tl-hero__grid">
      <div class="tl-hero__copy">
        <span class="tl-eyebrow">{{ section.settings.eyebrow }}</span>
        <h1 class="tl-heading tl-heading--xl tl-hero__title">{{ section.settings.heading }}</h1>
        <p class="tl-body tl-hero__sub">{{ section.settings.subheading }}</p>
        <div class="tl-hero__ctas">
          {% if section.settings.button_link != blank %}
            <a href="{{ section.settings.button_link }}" class="tl-btn tl-btn--red">{{ section.settings.button_label }}</a>
          {% endif %}
          {% if section.settings.secondary_link != blank %}
            <a href="{{ section.settings.secondary_link }}" class="tl-btn tl-btn--outline-light">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
        <div class="tl-hero__stats">
          {% for block in section.blocks %}
            {% if block.type == 'stat' %}
              <div class="tl-stat">
                <span class="tl-stat__number">{{ block.settings.number }}</span>
                <span class="tl-stat__label">{{ block.settings.label }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="tl-hero__media">
        <div class="tl-hero__glow"></div>
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'eager' }}
        {% else %}
          <div class="tl-hero__placeholder">Product image<br>goes here</div>
        {% endif %}
      </div>
    </div>
  </div>
  <div class="tl-wavelength"></div>
</div>

{% schema %}
{
  "name": "Thrivve Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "660NM + 850NM RED LIGHT THERAPY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stronger hair starts with light."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clinical-grade red and near-infrared light therapy, built into a cap you wear for 10 minutes a day. No clinic visits. No chemicals."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop the cap"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "How it works"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "94%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Reported visible results"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thrivve Hero",
      "blocks": [
        { "type": "stat", "settings": { "number": "94%", "label": "Reported visible results" } },
        { "type": "stat", "settings": { "number": "10 MIN", "label": "Per day" } },
        { "type": "stat", "settings": { "number": "FDA", "label": "Cleared wavelengths" } }
      ]
    }
  ]
}
{% endschema %}
