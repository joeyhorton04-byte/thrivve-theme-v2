            "custom_liquid": "{{ 'thrivve-tokens.css' | asset_url | stylesheet_tag }}\n\n{%- assign carousel_id = 'rc-' | append: section.id -%}\n\n<div class=\"tl-review-carousel\" id=\"{{ carousel_id }}\">\n  <div class=\"tl-review-carousel__slide\">\n    <p class=\"tl-review-carousel__quote\">I've never bought anything from social media before, but this was worth it. After a month, my hair actually feels a bit thicker!</p>\n    <div class=\"tl-review-carousel__meta\">\n      <span class=\"tl-review-carousel__author\">Jamie R.</span>\n      <span class=\"tl-review-carousel__stars\" aria-hidden=\"true\">★★★★★</span>\n    </div>\n  </div>\n\n  <div class=\"tl-review-carousel__slide\" hidden>\n    <p class=\"tl-review-carousel__quote\">I love how comfortable it feels while delivering red light therapy to my scalp without getting in the way.</p>\n    <div class=\"tl-review-carousel__meta\">\n      <span class=\"tl-review-carousel__author\">Michael T.</span>\n      <span class=\"tl-review-carousel__stars\" aria-hidden=\"true\">★★★★★</span>\n    </div>\n  </div>\n\n  <div class=\"tl-review-carousel__slide\" hidden>\n    <p class=\"tl-review-carousel__quote\">A great hands-free option for supporting hair growth at home with a device that feels practical and modern.</p>\n    <div class=\"tl-review-carousel__meta\">\n      <span class=\"tl-review-carousel__author\">Samantha L.</span>\n      <span class=\"tl-review-carousel__stars\" aria-hidden=\"true\">★★★★★</span>\n    </div>\n  </div>\n\n  <div class=\"tl-review-carousel__controls\">\n    <button type=\"button\" class=\"tl-review-carousel__arrow\" data-review-prev aria-label=\"Previous review\">‹</button>\n    <div class=\"tl-review-carousel__dots\" data-review-dots>\n      <button type=\"button\" class=\"tl-review-carousel__dot is-active\" data-review-dot aria-label=\"Go to review 1\"></button>\n      <button type=\"button\" class=\"tl-review-carousel__dot\" data-review-dot aria-label=\"Go to review 2\"></button>\n      <button type=\"button\" class=\"tl-review-carousel__dot\" data-review-dot aria-label=\"Go to review 3\"></button>\n    </div>\n    <button type=\"button\" class=\"tl-review-carousel__arrow\" data-review-next aria-label=\"Next review\">›</button>\n  </div>\n</div>\n\n<style>\n  .tl-review-carousel {\n    margin-top: 1.6rem;\n    padding-top: 1.6rem;\n    border-top: 1px solid var(--tl-border-dark);\n  }\n  .tl-review-carousel__quote {\n    font-family: var(--tl-font-body);\n    font-size: 1.5rem;\n    line-height: 1.55;\n    color: var(--tl-black);\n    margin: 0 0 1rem;\n  }\n  .tl-review-carousel__meta {\n    display: flex;\n    align-items: center;\n    gap: 1rem;\n  }\n  .tl-review-carousel__author {\n    font-family: var(--tl-font-body);\n    font-size: 1.3rem;\n    font-style: italic;\n    color: var(--tl-gray);\n  }\n  .tl-review-carousel__stars {\n    color: #f5a623;\n    font-size: 1.4rem;\n    letter-spacing: 0.1em;\n  }\n  .tl-review-carousel__controls {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 1.6rem;\n    margin-top: 1.6rem;\n  }\n  .tl-review-carousel__arrow {\n    background: none;\n    border: none;\n    cursor: pointer;\n    font-size: 2rem;\n    line-height: 1;\n    color: var(--tl-gray);\n    padding: 0.4rem 0.8rem;\n  }\n  .tl-review-carousel__arrow:hover {\n    color: var(--tl-black);\n  }\n  .tl-review-carousel__dots {\n    display: flex;\n    align-items: center;\n    gap: 0.8rem;\n  }\n  .tl-review-carousel__dot {\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: var(--tl-border-dark);\n    border: none;\n    cursor: pointer;\n    padding: 0;\n  }\n  .tl-review-carousel__dot.is-active {\n    background: var(--tl-black);\n  }\n</style>\n\n<script>\n  (function () {\n    var root = document.getElementById('{{ carousel_id }}');\n    if (!root) return;\n    var slides = root.querySelectorAll('.tl-review-carousel__slide');\n    var dots = root.querySelectorAll('[data-review-dot]');\n    var prevBtn = root.querySelector('[data-review-prev]');\n    var nextBtn = root.querySelector('[data-review-next]');\n    var current = 0;\n    function show(index) {\n      if (index < 0) index = slides.length - 1;\n      if (index >= slides.length) index = 0;\n      current = index;\n      slides.forEach(function (slide, i) { slide.hidden = i !== current; });\n      dots.forEach(function (dot, i) { dot.classList.toggle('is-active', i === current); });\n    }\n    if (prevBtn) prevBtn.addEventListener('click', function () { show(current - 1); });\n    if (nextBtn) nextBtn.addEventListener('click', function () { show(current + 1); });\n    dots.forEach(function (dot, i) { dot.addEventListener('click', function () { show(i); }); });\n  })();\n</script>"
